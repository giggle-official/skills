{
  "name": "x2c-publish",
  "version": "1.0.0",
  "description": "X2C视频发布与资产管理",
  "main": "scripts/x2c-publish.js",
  "scripts": {
    "test": "node scripts/x2c-publish.js balance"
  },
  "api": {
    "baseUrl": "https://eumfmgwxwjyagsvqloac.supabase.co/functions/v1/open-api"
  },
  "features": {
    "distribution": {
      "description": "视频发布到X2C平台",
      "actions": [
        "categories",
        "upload-url",
        "publish",
        "query",
        "add-episodes",
        "list"
      ]
    },
    "wallet": {
      "description": "资产管理（X2C/USDC）",
      "actions": [
        "balance",
        "claim-x2c",
        "swap-x2c",
        "withdraw",
        "transactions"
      ]
    }
  },
  "multiUser": true,
  "credentials": {
    "field": "x2cApiKey",
    "path": "credentials/{USER_ID}.json"
  }
}
