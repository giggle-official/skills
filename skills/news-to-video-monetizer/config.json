          {"id": "热门综合", "label": "热门综合"},
          {"id": "霸总甜宠", "label": "霸总甜宠"},
          {"id": "仙侠古装", "label": "仙侠古装"}
        ],
        "en": [
          {"id": "Werewolf & Shifter", "label": "Werewolf & Shifter"},
          {"id": "Suspense & Horror", "label": "Suspense & Horror"},
          {"id": "Power & Revenge", "label": "Power & Revenge"},
