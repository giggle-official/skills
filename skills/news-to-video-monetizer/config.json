        {"id": "皮克斯", "label": "皮克斯"},
        {"id": "写实风格", "label": "写实"},
        {"id": "二次元", "label": "二次元"},
        {"id": "国风水墨", "label": "国风水墨"}
      ],
      "category": {
        "zh": [
          {"id": "玄幻异能", "label": "玄幻异能"},
          {"id": "悬疑惊悚", "label": "悬疑惊悚"},
          {"id": "科幻末世", "label": "科幻末世"},
