{
  "$schema": "task-lifecycle-v2",
  "version": "2.1.0",
  "description": "一次执行 = 一个 Task，5 节点生命周期。收益为账户级，不绑定 Task。",
  "task_id_format": "TASK-{YYYYMMDD}-{SEQ:3}",
  "lifecycle_nodes": [
    {"node": 1, "key": "collection", "label": "采集"},
    {"node": 2, "key": "filtering", "label": "筛选"},
    {"node": 3, "key": "production", "label": "制作"},
    {"node": 4, "key": "publishing", "label": "发布"},
    {"node": 5, "key": "audit", "label": "审核"}
  ],
  "node_statuses": ["pending", "running", "completed", "failed"],
  "task_statuses": ["created", "running", "completed", "failed"]
}
